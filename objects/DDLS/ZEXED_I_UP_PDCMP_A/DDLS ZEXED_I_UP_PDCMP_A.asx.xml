<SOURCE>@AbapCatalog.viewEnhancementCategory: [#NONE]
@AccessControl.authorizationCheck: #NOT_REQUIRED
@EndUserText.label: 'Upload PO - Class. Contab. (Intf.)'
@Metadata.ignorePropagatedAnnotations: false
define view entity ZEXED_I_UP_PDCMP_A
  as select from zexed_up_pdcmp_a

  association        to parent ZEXED_I_UP_PDCMP_I as _Item on $projection.ParentUUID = _Item.UUID

  association [1..1] to ZEXED_I_UP_PDCMP          as _File on $projection.FileUUID = _File.UUID
{
  key   uuid                                                                                   as UUID,
        parent_uuid                                                                            as ParentUUID,
        file_uuid                                                                              as FileUUID,
        purchase_order                                                                         as PurchaseOrder,
        item                                                                                   as Item,
        account_assignment_number                                                              as AccountAssignmentNumber,
        concat_with_space('Classificação Contábil:',ltrim( account_assignment_number, '0' ),1) as LabelAccountAssignment,
        cost_center                                                                            as CostCenter,
        proj_network                                                                           as ProjectNetwork,
        network_activity                                                                       as NetworkActivity,
        order_quantity_unit                                                                    as OrderQuantityUnit,
        quantity                                                                               as Quantity,
        document_currency                                                                      as DocumentCurrency,
        purg_doc_net_amount                                                                    as PurgDocNetAmount,
        mult_acct_assgmt_distr_percent                                                         as MultipleAcctAssgmtDistrPercent,
        glaccount                                                                              as GLAccount,
        local_created_by                                                                       as LocalCreatedBy,
        local_created_at                                                                       as LocalCreatedAt,
        local_last_changed_by                                                                  as LocalLastChangedBy,
        local_last_changed_at                                                                  as LocalLastChangedAt,
        last_changed_at                                                                        as LastChangedAt,
        //Associations
        _Item,
        _File
}
