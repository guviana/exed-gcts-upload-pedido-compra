<SOURCE>@AccessControl.authorizationCheck: #NOT_REQUIRED
@EndUserText.label: 'Consumption View for zexed_I_UP_PDCMP_I'
@Metadata.ignorePropagatedAnnotations: false
@VDM.viewType: #CONSUMPTION
@Metadata.allowExtensions: true
define view entity ZEXED_C_UP_PDCMP_I
  as projection on ZEXED_I_UP_PDCMP_I
{
  key   UUID,
        ParentUUID,
        FileUUID,
        PurchaseOrder,
        Item,
        LabelItem,
        @Consumption.valueHelpDefinition: [{
          entity: { name: 'I_ProductDescription_2', element: 'Product' },
          useForValidation: true,
          additionalBinding: [
            { element: 'Language', localElement: 'Language', usage: #FILTER },
            { element: 'ProductDescription', localElement: 'MaterialName', usage: #RESULT }
          ]
        }]
        @Search.defaultSearchElement: true
        @Search.fuzzinessThreshold: 0.8
        @ObjectModel.text.element: [ 'MaterialName' ]
        @UI.textArrangement: #TEXT_FIRST
        Material,
        @EndUserText.label: 'Material'
        MaterialName,
        @EndUserText.label: 'Centro'
        @Consumption.valueHelpDefinition: [{
          entity: { name: 'I_Plant', element: 'Plant' },
          useForValidation: true,
          additionalBinding: [
            { element: 'PlantName', localElement: 'PlantName', usage: #RESULT }
          ]
        }]
        @Search.defaultSearchElement: true
        @Search.fuzzinessThreshold: 0.8
        @ObjectModel.text.element: [ 'PlantName' ]
        @UI.textArrangement: #TEXT_FIRST
        Plant,
        PlantName,
        @Consumption.valueHelpDefinition: [{
        entity: { name: 'I_Currency', element: 'Currency' },
        useForValidation: true
        }]
        @Semantics.currencyCode: true
        DocumentCurrency,
        @Consumption.valueHelpDefinition: [{
        entity: { name: 'I_UnitOfMeasure', element: 'UnitOfMeasure' }
//        useForValidation: true
        }]
        @Semantics.unitOfMeasure: true
        PurchaseOrderQuantityUnit,
        @Semantics.amount.currencyCode: 'DocumentCurrency'
        NetPriceAmount,
        @Semantics.quantity.unitOfMeasure: 'PurchaseOrderQuantityUnit'
        OrderQuantity,
        @Consumption.valueHelpDefinition: [{
          entity: { name: 'I_PurchaseRequisitionAPI01', element: 'PurchaseRequisition' },
          useForValidation: true
        }]
        PurchaseRequisition,
        @Consumption.valueHelpDefinition: [{
        entity: { name: 'I_PurchaseRequisitionItemAPI01', element: 'PurchaseRequisitionItem' },
        useForValidation: true,
        additionalBinding: [
        { element: 'PurchaseRequisition', localElement: 'PurchaseRequisition', usage: #FILTER }
        ]
        }]
        PurchaseRequisitionItem,
        @Consumption.valueHelpDefinition: [{
        entity: { name: 'I_UnitOfMeasure', element: 'UnitOfMeasure' }
//        useForValidation: true
        }]
        //        @Semantics.unitOfMeasure: true
        BaseUnit,
        @Consumption.valueHelpDefinition: [{
        entity: { name: 'I_AcctAssgmtDistrIndicatorTxt', element: 'MultipleAcctAssgmtDistribution' },
          useForValidation: true,
          additionalBinding: [
            { element: 'DistributionKeyText', localElement: 'DistributionKeyText', usage: #RESULT }
          ]
        }]
        @ObjectModel.text.element: [ 'DistributionKeyText' ]
        @UI.textArrangement: #TEXT_FIRST
        MultipleAcctAssgmtDistribution,
        DistributionKeyText,
        AccountAssignmentCategory,
        @Consumption.valueHelpDefinition: [{
        entity: { name: 'I_TaxCode', element: 'TaxCode' },
        useForValidation: true
        }]
        TaxCode,
        Language,
        LocalCreatedBy,
        LocalCreatedAt,
        LocalLastChangedBy,
        LocalLastChangedAt,
        LastChangedAt,
        /* Associations */
        _Header        : redirected to parent ZEXED_C_UP_PDCMP_H,
        _File          : redirected to ZEXED_C_UP_PDCMP,
        _AccAssignment : redirected to composition child ZEXED_C_UP_PDCMP_A
}
