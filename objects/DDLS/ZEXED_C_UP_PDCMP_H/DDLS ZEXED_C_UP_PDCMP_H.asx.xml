<SOURCE>@AccessControl.authorizationCheck: #NOT_REQUIRED
@EndUserText.label: 'Consumption View for zexed_I_UP_PDCMP_H'
@Metadata.allowExtensions: true
@Metadata.ignorePropagatedAnnotations: false
@VDM.viewType: #CONSUMPTION
@Search.searchable: true
define view entity ZEXED_C_UP_PDCMP_H
  as projection on ZEXED_I_UP_PDCMP_H
{
  key   UUID,
        ParentUUID,
        Status,
        CriticalityStatus,
        PurchaseOrder,
        LabelPurchaseOrder,
        @Consumption.valueHelpDefinition: [{
          entity: { name: 'I_PurchasingDocumentType', element: 'PurchasingDocumentType' },
          useForValidation: true,
          additionalBinding: [
              { element: 'PurchasingDocumentCategory', localConstant: 'F', usage: #FILTER }
          ]
        }]
        PurchaseOrderType2,
        PurchaseOrderDate,
        @Consumption.valueHelpDefinition: [{
          entity: { name: 'I_CompanyCode', element: 'CompanyCode' },
          useForValidation: true,
          additionalBinding: [
              { element: 'CompanyCodeName', localElement: 'CompanyName', usage: #RESULT }
          ]
        }]
        @Search.defaultSearchElement: true
        @Search.fuzzinessThreshold: 0.8
        @ObjectModel.text.element: [ 'CompanyName' ]
        @UI.textArrangement: #TEXT_FIRST
        CompanyCode,
        @Consumption.valueHelpDefinition: [{
          entity: { name: 'I_PurchasingOrganization', element: 'PurchasingOrganization' },
          useForValidation: true,
          additionalBinding: [
              { element: 'PurchasingOrganizationName', localElement: 'PurchaseOrganizationName', usage: #RESULT }
          ]
        }]
        @Search.defaultSearchElement: true
        @Search.fuzzinessThreshold: 0.8
        @ObjectModel.text.element: [ 'PurchaseOrganizationName' ]
        @UI.textArrangement: #TEXT_FIRST
        PurchaseOrganization,
        @Consumption.valueHelpDefinition: [{
          entity: { name: 'I_PurchasingGroup', element: 'PurchasingGroup' },
          useForValidation: true,
          additionalBinding: [
              { element: 'PurchasingGroupName', localElement: 'PurchaseGroupName', usage: #RESULT }
          ]
        }]
        @Search.defaultSearchElement: true
        @Search.fuzzinessThreshold: 0.8
        @ObjectModel.text.element: [ 'PurchaseGroupName' ]
        @UI.textArrangement: #TEXT_FIRST
        PurchaseGroup,
        @Consumption.valueHelpDefinition: [{
          entity: { name: 'I_Supplier', element: 'Supplier' },
          useForValidation: true,
          additionalBinding: [
              { element: 'BPSupplierFullName', localElement: 'SupplierName', usage: #RESULT }
          ]
        }]
        @Search.defaultSearchElement: true
        @Search.fuzzinessThreshold: 0.8
        @ObjectModel.text.element: [ 'SupplierName' ]
        @UI.textArrangement: #TEXT_LAST
        Supplier,
        @Consumption.valueHelpDefinition: [{
          entity: { name: 'I_PaymentTerms', element: 'PaymentTerms' },
          useForValidation: true
        }]
        @Search.defaultSearchElement: true
        @Search.fuzzinessThreshold: 0.8
        PaymentTerms,
        CompanyName,
        SupplierName,
        PurchaseOrganizationName,
        PurchaseGroupName,
        NameUserCreate,
        @Search.defaultSearchElement: true
        @Search.fuzzinessThreshold: 0.8
        @ObjectModel.text.element: [ 'NameUserCreate' ]
        @UI.textArrangement: #TEXT_FIRST
        LocalCreatedBy,
        LocalCreatedAt,
        NameUserChange,
        @ObjectModel.text.element: [ 'NameUserChange' ]
        @UI.textArrangement: #TEXT_FIRST
        LocalLastChangedBy,
        LocalLastChangedAt,
        LastChangedAt,
        /* Associations */
        _File  : redirected to parent ZEXED_C_UP_PDCMP,
        _Itens : redirected to composition child ZEXED_C_UP_PDCMP_I
}
