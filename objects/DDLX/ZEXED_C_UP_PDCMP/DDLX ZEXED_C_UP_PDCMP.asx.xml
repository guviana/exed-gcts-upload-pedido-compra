  @UI.dataPoint:      { qualifier: 'tqStatus', title: 'Status Arquivo', criticality: 'CriticalityStatus' } // Posição Header Object Page
  FileStatus;

  //──────────────────────────────────────────────────────────
  // Criado Por
  //──────────────────────────────────────────────────────────
  @EndUserText.label: 'Criado Por'
  @UI.selectionField: [ { position: 20 } ]
  @UI.lineItem:       [ { position: 40, label: 'Responsável' } ]
  @UI.dataPoint:      { qualifier: 'tqEndUser', title: 'Responsável' }
  @UI.fieldGroup:     [ { qualifier: 'idAdminDataGroup', position: 10 } ]
  LocalCreatedBy;

  //──────────────────────────────────────────────────────────
  // Criado Em
  //──────────────────────────────────────────────────────────
  @EndUserText.label: 'Criado Em'
  @UI.selectionField: [ { position: 30 } ]
  @UI.lineItem:       [ { position: 50, label: 'Criado Em' } ]
  @UI.dataPoint:      { qualifier: 'tqChgAt', title: 'Criado Em' }
  @UI.fieldGroup:     [ { qualifier: 'idAdminDataGroup', position: 20 } ]
  LocalCreatedAt;

  //──────────────────────────────────────────────────────────
  // Ultima Alteração
  //──────────────────────────────────────────────────────────
  @EndUserText.label: 'Última Alteração'
  @UI.selectionField: [ { position: 40 } ]
  @UI.lineItem:       [ { position: 60, label: 'Última Alteração' } ]
  @UI.fieldGroup:     [ { qualifier: 'idAdminDataGroup', position: 30 } ]
  LocalLastChangedAt;

  //──────────────────────────────────────────────────────────
  // Arquivo
  //──────────────────────────────────────────────────────────
  @EndUserText.label: 'Arquivo'
  @UI.selectionField: [ { position: 50 } ]
  @UI.fieldGroup:     [ { position: 10, qualifier: 'idDemandDetailsGroup' } ]
  FileContent;


  //──────────────────────────────────────────────────────────
  // Ultima Alteração
  //──────────────────────────────────────────────────────────
  @EndUserText.label: 'Alterado Por'
  @UI.selectionField: [ { position: 50 } ]
  @UI.fieldGroup:     [ { qualifier: 'idAdminDataGroup', position: 40 } ]
  LocalLastChangedBy;

  //──────────────────────────────────────────────────────────
  // Tipo do Arquivo
  //──────────────────────────────────────────────────────────
  @UI.hidden: true
  Mimetype;
