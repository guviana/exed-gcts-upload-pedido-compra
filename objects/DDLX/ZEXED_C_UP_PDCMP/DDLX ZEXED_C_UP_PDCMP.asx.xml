  // Nome do Arquivo
  //──────────────────────────────────────────────────────────
  @EndUserText.label: 'Nome do Arquivo'
  @UI.selectionField: [ { position: 10 } ]
  @UI.lineItem:       [ { position: 20, label: 'Nome do Arquivo' } ]
  Filename;

  //──────────────────────────────────────────────────────────
  // Status do Arquivo
  //──────────────────────────────────────────────────────────
  @EndUserText.label: 'Status Arquivo'
